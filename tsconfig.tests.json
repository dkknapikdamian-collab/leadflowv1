{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".tests-dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "lib/constants.ts",
    "lib/types.ts",
    "lib/utils.ts",
    "lib/seed.ts",
    "lib/snapshot.ts",
    "lib/today.ts",
    "lib/access/**/*.ts",
    "lib/auth/**/*.ts",
    "lib/mail/**/*.ts",
    "lib/supabase/**/*.ts",
    "lib/repository/**/*.ts",
    "lib/data/**/*.ts",
    "tests/**/*.ts"
  ]
}
