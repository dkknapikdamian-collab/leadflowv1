# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# CloseFlow AI env policy
# Server-only. Never prefix with VITE_ and never expose to frontend code.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CloseFlow AI operator
VITE_AI_USAGE_UNLIMITED=true

<!-- closeflow-supabase-first-env-policy -->
# CloseFlow architecture policy
# Supabase is the target source of truth for business data, auth, storage, billing,
# client portal, AI drafts, templates and activity.
# Firebase / Firestore is legacy and must not receive new business features.
# Do not trust x-user-id, x-user-email or x-workspace-id from frontend requests.
# AI can create drafts only; final records require user confirmation.
<!-- /closeflow-supabase-first-env-policy -->


<!-- closeflow-stage01-supabase-auth-env -->
# CloseFlow Stage 01 — Supabase Auth
# Frontend-safe public config. The anon key is public by design.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side Supabase config. Never expose service role key with VITE_ prefix.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
<!-- /closeflow-stage01-supabase-auth-env -->
