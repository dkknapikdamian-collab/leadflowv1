# Public app URL used for Supabase redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Public key for browser and server auth requests.
# Use either the new publishable key or, if your project still exposes it, the anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Future billing config.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Future mail config.
MAIL_FROM=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Optional future server-side Supabase admin work.
SUPABASE_SERVICE_ROLE_KEY=
