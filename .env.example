# Public app URL used for Supabase redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Public key for browser and server auth requests.
# Use either the new publishable key or, if your project still exposes it, the anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Future billing config.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mail config used by application system emails.
MAIL_FROM=
RESEND_API_KEY=
CRON_SECRET=
SYSTEM_MAILS_CRON_SECRET=

# SMTP values used for Supabase Auth custom SMTP setup in dashboard.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Server-only admin access for system email sweeps and future billing/webhooks.
SUPABASE_SERVICE_ROLE_KEY=
