# CloseFlow .env.example
# Nie wpisuj tu prawdziwych sekretów. Ten plik jest tylko szablonem.

# -----------------------------------------------------------------------------
# Public client env
# -----------------------------------------------------------------------------
# Te wartości mogą być dostępne w przeglądarce. Anon key Supabase jest publiczny
# z założenia, ale dostęp musi być zabezpieczony przez RLS i endpointy API.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Server-only Supabase env
# -----------------------------------------------------------------------------
# Nigdy nie dodawaj service role key jako VITE_*.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# App / hosting
# -----------------------------------------------------------------------------
# Publiczny URL aplikacji, np. https://closeflow.pl albo URL z Vercel.

APP_URL=
VERCEL_URL=

# -----------------------------------------------------------------------------
# Billing / payments
# -----------------------------------------------------------------------------
# Uzupełnij tylko wtedy, gdy billing jest realnie testowany i wdrażany.
# Nazwy mogą wymagać dopasowania do aktualnego providera w repo.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_AI_MONTHLY=

# -----------------------------------------------------------------------------
# Email / digest
# -----------------------------------------------------------------------------

RESEND_API_KEY=
DIGEST_FROM_EMAIL=
CRON_SECRET=

# -----------------------------------------------------------------------------
# AI backend-only
# -----------------------------------------------------------------------------
# Sekrety AI są tylko po stronie serwera. Nie używaj prefiksu VITE_ dla sekretów AI.

GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Legacy / decommission notes
# -----------------------------------------------------------------------------
# Firebase / Firestore nie jest docelowym źródłem prawdy. Nie dodawaj nowych
# funkcji biznesowych do Firestore. Jeśli stare moduły nadal wymagają legacy
# configu, trzymaj go osobno i opisz w dokumentacji migracyjnej.
# Admin role policy
# Prefer Supabase profiles.role = admin.
# Optional server-only bootstrap allowlist. Never expose this as VITE_*.
CLOSEFLOW_SERVER_ADMIN_EMAILS=
# CloseFlow admin policy
# Admin is configured in Supabase, not in frontend env:
# public.profiles.role = 'admin'
# public.profiles.is_admin = true is supported only as legacy compatibility.

# -----------------------------------------------------------------------------
# Client portal security, server-only
# -----------------------------------------------------------------------------
# W produkcji te wartości są wymagane. Zmiana PORTAL_TOKEN_PEPPER unieważnia
# wcześniej wygenerowane linki portalu, bo tokeny są trzymane jako hash.
# Nie używaj prefiksu VITE_.

PORTAL_TOKEN_PEPPER=
PORTAL_SESSION_SECRET=

# App owner/developer identity. Prefer UID in production; email is fallback only.
CLOSEFLOW_APP_OWNER_UIDS=
CLOSEFLOW_SERVER_APP_OWNER_UIDS=
CLOSEFLOW_ADMIN_EMAILS=
