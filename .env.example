# LeadFlow - environment template
#
# Zasady:
# - NEXT_PUBLIC_* trafia do frontu i może być używane po stronie klienta.
# - Reszta kluczy jest prywatna i może być używana tylko na backendzie,
#   w route handlers, server actions lub integracjach serwerowych.
# - Nie wpisuj tutaj prawdziwych danych użytkowników.
# - Nie commituj lokalnych .env.* z realnymi sekretami.

# =========================================================
# PUBLIC / CLIENT
# =========================================================
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# =========================================================
# SERVER / PRIVATE
# =========================================================
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# =========================================================
# GOOGLE AUTH
# =========================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =========================================================
# RESEND / SMTP
# =========================================================
RESEND_API_KEY=
MAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# =========================================================
# BILLING
# =========================================================
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
PRICE_ID_MONTHLY=
PRICE_ID_YEARLY=
TRIAL_DAYS=7

# =========================================================
# OPTIONAL APP / OPS
# =========================================================
DEFAULT_TIMEZONE=Europe/Warsaw
LOG_LEVEL=info

# =========================================================
# ENVIRONMENT NOTES
# =========================================================
# local:
#   NEXT_PUBLIC_APP_ENV=development
#   NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# preview / staging:
#   NEXT_PUBLIC_APP_ENV=preview
#   NEXT_PUBLIC_APP_URL=https://preview-twoj-projekt.vercel.app
#
# production:
#   NEXT_PUBLIC_APP_ENV=production
#   NEXT_PUBLIC_APP_URL=https://twoja-domena.pl
