# CloseFlow .env.example
# Nie wpisuj tu prawdziwych sekretów. Ten plik jest tylko szablonem.

# -----------------------------------------------------------------------------
# Public client env
# -----------------------------------------------------------------------------
# Te wartości mogą być dostępne w przeglądarce. Anon key Supabase jest publiczny
# z założenia, ale dostęp musi być zabezpieczony przez RLS i endpointy API.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Server-only Supabase env
# -----------------------------------------------------------------------------
# Nigdy nie dodawaj service role key jako VITE_*.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# App / hosting
# -----------------------------------------------------------------------------
# Publiczny URL aplikacji, np. https://closeflow.pl albo URL z Vercel.

APP_URL=
VERCEL_URL=

# -----------------------------------------------------------------------------
# Billing / payments
# -----------------------------------------------------------------------------
# Uzupełnij tylko wtedy, gdy billing jest realnie testowany i wdrażany.
# Nazwy mogą wymagać dopasowania do aktualnego providera w repo.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_AI_MONTHLY=

# -----------------------------------------------------------------------------
# Email / digest
# -----------------------------------------------------------------------------

RESEND_API_KEY=
DIGEST_FROM_EMAIL=
CRON_SECRET=

# -----------------------------------------------------------------------------
# AI backend-only
# -----------------------------------------------------------------------------
# Sekrety AI są tylko po stronie serwera. Nie twórz VITE_GEMINI_API_KEY.

GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Legacy / decommission notes
# -----------------------------------------------------------------------------
# Firebase / Firestore nie jest docelowym źródłem prawdy. Nie dodawaj nowych
# funkcji biznesowych do Firestore. Jeśli stare moduły nadal wymagają legacy
# configu, trzymaj go osobno i opisz w dokumentacji migracyjnej.
