# CloseFlow .env.example
# Nie wpisuj tu prawdziwych sekretw. Ten plik jest tylko szablonem.

# -----------------------------------------------------------------------------
# Public client env
# -----------------------------------------------------------------------------
# Te wartoci mogą być dostępne w przeglądarce. Anon key Supabase jest publiczny
# z zaoenia, ale dostęp musi być zabezpieczony przez RLS i endpointy API.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Server-only Supabase env
# -----------------------------------------------------------------------------
# Nigdy nie dodawaj service role key jako VITE_*.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# App / hosting
# -----------------------------------------------------------------------------
# Publiczny URL aplikacji, np. https://closeflow.pl albo URL z Vercel.

APP_URL=
VERCEL_URL=

# -----------------------------------------------------------------------------
# Billing / payments
# -----------------------------------------------------------------------------
# Uzupenij tylko wtedy, gdy billing jest realnie testowany i wdraany.
# Nazwy mogą wymagać dopasowania do aktualnego providera w repo.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_AI_MONTHLY=

# -----------------------------------------------------------------------------
# Email / digest
# -----------------------------------------------------------------------------

RESEND_API_KEY=
DIGEST_FROM_EMAIL=
CRON_SECRET=

# -----------------------------------------------------------------------------
# AI backend-only
# -----------------------------------------------------------------------------
# Sekrety AI są tylko po stronie serwera. Nie uywaj prefiksu VITE_ dla sekretw AI.

GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Legacy / decommission notes
# -----------------------------------------------------------------------------
# Firebase / Firestore nie jest docelowym rdem prawdy. Nie dodawaj nowych
# funkcji biznesowych do Firestore. Jeli stare moduy nadal wymagają legacy
# configu, trzymaj go osobno i opisz w dokumentacji migracyjnej.
# Admin role policy
# Prefer Supabase profiles.role = admin.
# Optional server-only bootstrap allowlist. Never expose this as VITE_*.
CLOSEFLOW_SERVER_ADMIN_EMAILS=
# CloseFlow admin policy
# Admin is configured in Supabase, not in frontend env:
# public.profiles.role = 'admin'
# public.profiles.is_admin = true is supported only as legacy compatibility.

# -----------------------------------------------------------------------------
# Client portal security, server-only
# -----------------------------------------------------------------------------
# W produkcji te wartoci są wymagane. Zmiana PORTAL_TOKEN_PEPPER uniewania
# wczeniej wygenerowane linki portalu, bo tokeny są trzymane jako hash.
# Nie uywaj prefiksu VITE_.

PORTAL_TOKEN_PEPPER=
PORTAL_SESSION_SECRET=

# App owner/developer identity. Prefer UID in production; email is fallback only.
CLOSEFLOW_APP_OWNER_UIDS=
CLOSEFLOW_SERVER_APP_OWNER_UIDS=
CLOSEFLOW_ADMIN_EMAILS=

# Stripe billing production validation
STRIPE_PRICE_BASIC_MONTHLY_PLN=19
STRIPE_PRICE_BASIC_YEARLY_PLN=190
STRIPE_PRICE_PRO_MONTHLY_PLN=39
STRIPE_PRICE_PRO_YEARLY_PLN=390
STRIPE_PRICE_AI_MONTHLY_PLN=69
STRIPE_PRICE_AI_YEARLY_PLN=690
# -----------------------------------------------------------------------------
# Client portal upload storage, server-only
# -----------------------------------------------------------------------------
# Bucket prywatny. Upload idzie tylko przez backend z SUPABASE_SERVICE_ROLE_KEY.
# Nie uywaj prefiksu VITE_ dla sekretw i ustawie backendowych storage.

SUPABASE_PORTAL_BUCKET=portal-uploads
PORTAL_UPLOAD_MAX_BYTES=10485760
PORTAL_UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document
PORTAL_STORAGE_HEALTH_SECRET=

