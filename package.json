{
  "name": "clientpilot",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "test": "tsc -p tsconfig.tests.json && node --test .tests-dist/tests/**/*.test.js",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "smoke:prod:build": "node scripts/smoke-prod.mjs --build",
    "verify:prod": "npm test && npm run build"
  },
  "dependencies": {
    "next": "16.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "5.9.3"
  }
}

