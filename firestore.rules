rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // ETAP 03 — Firebase legacy lockdown
    // Firebase/Firestore is legacy. Supabase is the source of truth.
    // Firebase is legacy. Do not add new business data here.
    //
    // Security goal:
    // - no public client portal token reads,
    // - no portal access based only on caseId,
    // - no token existence checks as authorization,
    // - only authenticated owners can read/write legacy Firestore data.
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwnerId(ownerId) {
      return isAuthenticated() && ownerId == request.auth.uid;
    }

    function existingOwner() {
      return isAuthenticated()
        && resource != null
        && resource.data.ownerId == request.auth.uid;
    }

    function newOwner() {
      return isAuthenticated()
        && request.resource != null
        && request.resource.data.ownerId == request.auth.uid;
    }

    function existingProfileOwner(profileId) {
      return isAuthenticated()
        && (
          profileId == request.auth.uid
          || (resource != null && resource.data.ownerId == request.auth.uid)
          || (resource != null && resource.data.uid == request.auth.uid)
        );
    }

    function newProfileOwner(profileId) {
      return isAuthenticated()
        && (
          profileId == request.auth.uid
          || (request.resource != null && request.resource.data.ownerId == request.auth.uid)
          || (request.resource != null && request.resource.data.uid == request.auth.uid)
        );
    }

    function isCaseOwner(caseId) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/cases/$(caseId)).data.ownerId == request.auth.uid;
    }

    match /profiles/{profileId} {
      allow get, list: if existingProfileOwner(profileId);
      allow create: if newProfileOwner(profileId);
      allow update, delete: if existingProfileOwner(profileId) && newProfileOwner(profileId);
    }

    match /workspaces/{workspaceId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /leads/{leadId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /clients/{clientId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /tasks/{taskId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /events/{eventId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /cases/{caseId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();

      match /items/{itemId} {
        allow get, list: if isCaseOwner(caseId);
        allow create, update, delete: if isCaseOwner(caseId);
      }
    }

    // Legacy fallback only: if top-level case_items exists, never expose it publicly.
    match /case_items/{itemId} {
      allow read, write: if false;
    }

    match /activities/{activityId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /work_items/{workItemId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /payments/{paymentId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /support_requests/{requestId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /service_profiles/{profileId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /ai_drafts/{draftId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /templates/{templateId} {
      allow get, list: if existingOwner();
      allow create: if newOwner();
      allow update, delete: if existingOwner() && newOwner();
    }

    match /client_portal_tokens/{tokenId} {
      // Legacy portal tokens are fully disabled in Firestore.
      // Portal V1 runs through Supabase + backend validation only.
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
