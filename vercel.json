{
  "crons": [
    {
      "path": "/api/daily-digest",
      "schedule": "5 5 * * *"
    },
    {
      "path": "/api/weekly-report",
      "schedule": "15 6 * * 1"
    }
  ],
  "rewrites": [
    {
      "source": "/api/tasks",
      "destination": "/api/work-items?kind=tasks"
    },
    {
      "source": "/api/events",
      "destination": "/api/work-items?kind=events"
    },
    {
      "source": "/api/response-templates",
      "destination": "/api/system?kind=response-templates"
    },
    {
      "source": "/api/case-templates",
      "destination": "/api/system?kind=case-templates"
    },
    {
      "source": "/api/support-forward",
      "destination": "/api/system?kind=support&route=forward"
    },
    {
      "source": "/api/support-requests",
      "destination": "/api/system?kind=support&route=requests"
    },
    {
      "source": "/api/daily-digest",
      "destination": "/api/system?kind=daily-digest"
    },
    {
      "source": "/api/workspace-subscription",
      "destination": "/api/system?kind=workspace-subscription"
    },
    {
      "source": "/api/profile-settings",
      "destination": "/api/system?kind=profile-settings"
    },
    {
      "source": "/api/workspace-settings",
      "destination": "/api/system?kind=workspace-settings"
    },
    {
      "source": "/api/admin/workspace-recovery",
      "destination": "/api/system?kind=workspace-recovery"
    },
    {
      "source": "/api/service-profiles",
      "destination": "/api/system?kind=service-profiles"
    },
    {
      "source": "/api/assistant/query",
      "destination": "/api/system?kind=assistant-query"
    },
    {
      "source": "/api/assistant",
      "destination": "/api/system?kind=ai-assistant"
    },
    {
      "source": "/api/assistant-context",
      "destination": "/api/system?kind=assistant-context"
    },
    {
      "source": "/api/payments",
      "destination": "/api/system?apiRoute=payments"
    },
    {
      "source": "/api/records",
      "destination": "/api/system?apiRoute=records"
    },
    {
      "source": "/api/client-portal-session",
      "destination": "/api/portal?route=session"
    },
    {
      "source": "/api/client-portal-tokens",
      "destination": "/api/portal?route=tokens"
    },
    {
      "source": "/api/google-calendar",
      "destination": "/api/system?kind=google-calendar"
    },
    {
      "source": "/api/billing-actions",
      "destination": "/api/billing-checkout?route=actions"
    },
    {
      "source": "/api/billing-webhook",
      "destination": "/api/stripe-webhook?route=webhook"
    },
    {
      "source": "/api/billing",
      "destination": "/api/billing-checkout?route=checkout"
    },
    {
      "source": "/((?!api/|assets/|.*\\..*).*)",
      "destination": "/"
    },
    {
      "source": "/api/weekly-report",
      "destination": "/api/system?kind=weekly-report"
    },
    {
      "source": "/api/support",
      "destination": "/api/system?kind=support"
    },
    {
      "source": "/api/portal",
      "destination": "/api/system?kind=portal"
    },
    {
      "source": "/api/storage-upload",
      "destination": "/api/system?kind=storage-upload"
    },
    {
      "source": "/api/storage-upload-health",
      "destination": "/api/system?kind=storage-upload-health"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/((?!api/|assets/|.*\\..*).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
